# ─────────────────────────────────────────
# REVOX CREATIVES BOT — ENV VARIABLES
# Copy this file, rename to .env, fill in values
# ─────────────────────────────────────────

# Your bot token from Discord Developer Portal
BOT_TOKEN=your_bot_token_here

# Your Discord Server (Guild) ID
GUILD_ID=your_guild_id_here

# Channel IDs — right-click channel → Copy Channel ID
WELCOME_CHANNEL_ID=your_welcome_channel_id
APPLICATIONS_CHANNEL_ID=your_applications_channel_id
ANNOUNCEMENTS_CHANNEL_ID=your_announcements_channel_id
LOGS_CHANNEL_ID=your_logs_channel_id

# Role IDs — Server Settings → Roles → right-click → Copy ID
CREATOR_ROLE_ID=your_creator_role_id
BRAND_ROLE_ID=your_brand_role_id
MEMBER_ROLE_ID=your_member_role_id
VERIFIED_ROLE_ID=your_verified_role_id
ADMIN_ROLE_ID=your_admin_role_id
